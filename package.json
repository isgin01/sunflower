  "license": "MIT",
  "engines": {
    "pnpm": ">=10",
    "runtime": {
      "name": "node",
      "version": ">=22.21.1"
    }
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-testing-library": "^7.13.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "typescript": "^5.8.3",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  }
