{
  "name": "sunflower-mono",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "scripts": {
    "start:android": "pnpm --filter sunflower-mobile run start",
    "build:android": "pnpm --filter sunflower-mobile run android",
    "test:mobile": "pnpm --filter sunflower-mobile run test",
    "prepare": "husky",
    "lint": "pnpm dlx eslint . --fix",
    "format": "pnpm dlx prettier -w .",
